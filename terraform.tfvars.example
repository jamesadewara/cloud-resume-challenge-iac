# Copy this to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars to git!

bucket_name          = "resume.jamesadewara.com"
domain_name          = "resume.jamesadewara.com"
cloudflare_api_token = "your-cloudflare-api-token"
cloudflare_zone_id   = "your-cloudflare-zone-id"
mongodb_uri          = "mongodb+srv://username:password@cluster.mongodb.net/resume_counter"
github_org           = "jamesadewara"
backend_repo_name    = "resume-api"